#!/usr/bin/env bash
set -euo pipefail

# /elon — Elon Musk AI Mentor Suite
# One-command installer for Claude Code and compatible agents

SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"

# Sub-skills (name -> subdirectory). The main /elon skill lives at the repo root.
SUB_SKILLS=("elon-think:think" "elon-plan:plan" "elon-build:build" "elon-review:review" "elon-test:test" "elon-ship:ship" "elon-retro:retro" "elon-hire:hire" "elon-focus:focus")

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${GREEN}▸${NC} $1"; }
warn()  { echo -e "${YELLOW}▸${NC} $1"; }
error() { echo -e "${RED}▸${NC} $1" >&2; }

echo ""
echo -e "${BOLD}⚡ /elon — Installing Elon Musk AI Mentor Suite (10 skills)${NC}"
echo ""

# Detect target
CLAUDE_SKILLS_DIR="$HOME/.claude/skills"
LOCAL=false

for arg in "$@"; do
  case "$arg" in
    --local) LOCAL=true ;;
    --help|-h)
      echo "Usage: ./setup [OPTIONS]"
      echo ""
      echo "Options:"
      echo "  --local    Install to ./.claude/skills/ (project-scoped)"
      echo "  --help     Show this message"
      exit 0
      ;;
  esac
done

if [ "$LOCAL" = true ]; then
  CLAUDE_SKILLS_DIR=".claude/skills"
  info "Installing locally to ${CLAUDE_SKILLS_DIR}/"
else
  info "Installing globally to ${CLAUDE_SKILLS_DIR}/"
fi

mkdir -p "${CLAUDE_SKILLS_DIR}"

INSTALLED=0

# --- Install main /elon skill ---
# If the repo is already at the skills dir (cloned directly to ~/.claude/skills/elon), no symlink needed.
# If cloned elsewhere, symlink it.
ELON_TARGET="${CLAUDE_SKILLS_DIR}/elon"
REAL_SKILL_DIR="$(cd "$SKILL_DIR" && pwd -P)"
REAL_TARGET=""
if [ -d "$ELON_TARGET" ] && [ ! -L "$ELON_TARGET" ]; then
  REAL_TARGET="$(cd "$ELON_TARGET" && pwd -P)"
fi

if [ "$REAL_SKILL_DIR" = "$REAL_TARGET" ]; then
  info "Installed /elon (already in place)"
  INSTALLED=$((INSTALLED + 1))
elif [ -L "$ELON_TARGET" ]; then
  rm "$ELON_TARGET"
  ln -s "$SKILL_DIR" "$ELON_TARGET"
  info "Installed /elon (updated symlink)"
  INSTALLED=$((INSTALLED + 1))
elif [ -d "$ELON_TARGET" ]; then
  warn "Existing /elon found — backing up to elon.bak"
  mv "$ELON_TARGET" "${ELON_TARGET}.bak"
  ln -s "$SKILL_DIR" "$ELON_TARGET"
  info "Installed /elon"
  INSTALLED=$((INSTALLED + 1))
else
  ln -s "$SKILL_DIR" "$ELON_TARGET"
  info "Installed /elon"
  INSTALLED=$((INSTALLED + 1))
fi

# --- Install sub-skills ---
for entry in "${SUB_SKILLS[@]}"; do
  SKILL_NAME="${entry%%:*}"
  SUB_DIR="${entry##*:}"
  SOURCE_DIR="${SKILL_DIR}/${SUB_DIR}"
  TARGET="${CLAUDE_SKILLS_DIR}/${SKILL_NAME}"

  if [ ! -f "${SOURCE_DIR}/SKILL.md" ]; then
    warn "Skipping ${SKILL_NAME} — SKILL.md not found"
    continue
  fi

  # Remove old symlink or back up existing directory
  if [ -L "$TARGET" ]; then
    rm "$TARGET"
  elif [ -d "$TARGET" ]; then
    mv "$TARGET" "${TARGET}.bak"
    warn "Backed up existing ${SKILL_NAME}"
  fi

  ln -s "$SOURCE_DIR" "$TARGET"
  info "Installed /${SKILL_NAME}"
  INSTALLED=$((INSTALLED + 1))
done

echo ""
echo -e "${GREEN}${BOLD}✓ ${INSTALLED} skills installed.${NC}"
echo ""
echo -e "  ${BOLD}/elon${NC}          General mentor — start here"
echo -e "  ${BOLD}/elon-think${NC}    First-principles thinking"
echo -e "  ${BOLD}/elon-plan${NC}     The Algorithm + project planning"
echo -e "  ${BOLD}/elon-build${NC}    Write code with extreme simplicity"
echo -e "  ${BOLD}/elon-review${NC}   Brutal honest code/design review"
echo -e "  ${BOLD}/elon-test${NC}     SpaceX testing philosophy"
echo -e "  ${BOLD}/elon-ship${NC}     Maniacal urgency to ship"
echo -e "  ${BOLD}/elon-retro${NC}    Learn from success and failure"
echo -e "  ${BOLD}/elon-hire${NC}     Build exceptional teams"
echo -e "  ${BOLD}/elon-focus${NC}    Find and attack the bottleneck"
echo ""
