#!/usr/bin/env bash
set -euo pipefail

# /elon — Elon Musk AI Mentor Suite
# One-command installer for Claude Code and compatible agents

SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"

# All skills in the suite
SKILLS=("elon" "elon-think" "elon-plan" "elon-build" "elon-review" "elon-test" "elon-ship" "elon-retro" "elon-hire" "elon-focus")
SKILL_DIRS=("." "think" "plan" "build" "review" "test" "ship" "retro" "hire" "focus")

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${GREEN}▸${NC} $1"; }
warn()  { echo -e "${YELLOW}▸${NC} $1"; }
error() { echo -e "${RED}▸${NC} $1" >&2; }

echo ""
echo -e "${BOLD}⚡ /elon — Installing Elon Musk AI Mentor Suite (10 skills)${NC}"
echo ""

# Detect target
CLAUDE_SKILLS_DIR="$HOME/.claude/skills"
LOCAL=false

for arg in "$@"; do
  case "$arg" in
    --local) LOCAL=true ;;
    --help|-h)
      echo "Usage: ./setup [OPTIONS]"
      echo ""
      echo "Options:"
      echo "  --local    Install to ./.claude/skills/ (project-scoped)"
      echo "  --help     Show this message"
      exit 0
      ;;
  esac
done

if [ "$LOCAL" = true ]; then
  CLAUDE_SKILLS_DIR=".claude/skills"
  info "Installing locally to ${CLAUDE_SKILLS_DIR}/"
else
  info "Installing globally to ${CLAUDE_SKILLS_DIR}/"
fi

mkdir -p "${CLAUDE_SKILLS_DIR}"

# Install each skill
INSTALLED=0
for i in "${!SKILLS[@]}"; do
  SKILL_NAME="${SKILLS[$i]}"
  SOURCE_DIR="${SKILL_DIR}/${SKILL_DIRS[$i]}"
  TARGET="${CLAUDE_SKILLS_DIR}/${SKILL_NAME}"

  # Verify SKILL.md exists
  if [ ! -f "${SOURCE_DIR}/SKILL.md" ]; then
    warn "Skipping ${SKILL_NAME} — SKILL.md not found"
    continue
  fi

  # Symlink
  if [ -L "$TARGET" ]; then
    rm "$TARGET"
  elif [ -d "$TARGET" ]; then
    if [ "$(cd "$TARGET" && pwd)" != "$SOURCE_DIR" ]; then
      mv "$TARGET" "${TARGET}.bak"
      warn "Backed up existing ${SKILL_NAME}"
    fi
  fi

  ln -sf "$SOURCE_DIR" "$TARGET"
  info "Installed /${SKILL_NAME}"
  INSTALLED=$((INSTALLED + 1))
done

echo ""
echo -e "${GREEN}${BOLD}✓ ${INSTALLED} skills installed.${NC}"
echo ""
echo -e "  ${BOLD}/elon${NC}          General mentor — start here"
echo -e "  ${BOLD}/elon-think${NC}    First-principles thinking"
echo -e "  ${BOLD}/elon-plan${NC}     The Algorithm + project planning"
echo -e "  ${BOLD}/elon-build${NC}    Write code with extreme simplicity"
echo -e "  ${BOLD}/elon-review${NC}   Brutal honest code/design review"
echo -e "  ${BOLD}/elon-test${NC}     SpaceX testing philosophy"
echo -e "  ${BOLD}/elon-ship${NC}     Maniacal urgency to ship"
echo -e "  ${BOLD}/elon-retro${NC}    Learn from success and failure"
echo -e "  ${BOLD}/elon-hire${NC}     Build exceptional teams"
echo -e "  ${BOLD}/elon-focus${NC}    Find and attack the bottleneck"
echo ""
